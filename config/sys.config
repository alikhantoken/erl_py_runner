[
  {erl_py_runner, [
    {environment, #{
      python => system,                          % 'system' or 'environment'.
      requirements => "python/requirements.txt", % Requirements file for 'environment' mode.
      runner => "python/runner.py",              % Python worker script path.
      venv_dir => ".venv"                        % Virtualenv folder for 'environment' mode.
    }},
    {worker, #{
      supervisor => #{
        intensity => 5, % Max worker restarts in the 'period' window.
        period => 30    % Restart window in seconds.
      },
      config => #{
        pool_size => 4,              % Number of Python workers, positive integer.
        max_pending => 128,          % Queue limit, integer or 'infinity'.
        exec_timeout => 60000,       % Script time limit in milliseconds.
        operation_timeout => 30000,  % Internal worker timeout in milliseconds.
        restart_delay => 250,        % Delay before worker restart in milliseconds.
        max_code_size => 1048576     % Max library code size in bytes.
      },
      modules_whitelist => #{
        % Modules Python allowed to call. Use a list or 'all' atom.
        erlang_modules => [
          math,
          lists,
          maps,
          binary,
          string
        ],
        % Modules scripts user can import. Use a list or 'all' atom.
        python_modules => [
          <<"math">>,
          <<"re">>,
          <<"datetime">>,
          <<"json">>
        ]
      }
    }}
  ]},
  {kernel, [
    %%% Global logger level
    {logger_level, info},
    %%% Handler configurations
    {logger, [
      {handler, console_handler, logger_std_h, #{
        level => info,
        config => #{
          type => file,
          file => "logs/console.log",
          max_no_bytes => 1073741824,           % 1 gigabyte
          max_no_files => 1,
          %% Message Queue Length
          sync_mode_qlen => 10000,
          drop_mode_qlen => 15000,
          flush_qlen => 20000,
          %% Bursts of Log Requests
          burst_limit_enable => false,
          %% Termination on Overload
          overload_kill_enable => true,
          overload_kill_qlen => 20000,
          overload_kill_mem_size => 2684354560, % 2.5 gigabytes
          overload_kill_restart_after => 1000   % millisecond
        },
        formatter => {logger_formatter, #{
          time_designator => $\s,
          template => [
            time, " ",
            "[", level, "] ",
            pid, "@",
            mfa, ":",
            line, " ",
            msg, "\n"
          ]
        }}
      }},
      {handler, error_handler, logger_std_h, #{
        level => error,
        config => #{
          type => file,
          file => "logs/error.log",
          max_no_bytes => 1073741824,           % 1 gigabyte
          max_no_files => 1,
          %% Message Queue Length
          sync_mode_qlen => 1000,
          drop_mode_qlen => 10000,
          flush_qlen => 15000,
          %% Bursts of Log Requests
          burst_limit_enable => false,
          %% Termination on Overload
          overload_kill_enable => true,
          overload_kill_qlen => 15000,
          overload_kill_mem_size => 1073741824, % 1 gigabyte
          overload_kill_restart_after => 1000   % milliseconds
        },
        formatter => {logger_formatter, #{
          time_designator => $\s,
          template => [
            time, " ",
            "[", level, "] ",
            pid, "@",
            mfa, ":",
            line, " ",
            msg, "\n"
          ]
        }}
      }}
    ]}
  ]}
].
